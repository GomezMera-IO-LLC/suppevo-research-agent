{
  "mcpServers": {
    "pubmed": {
      "command": "uvx",
      "args": ["suppevo-pubmed-mcp@latest"],
      "env": {
        "NCBI_API_KEY": ""
      },
      "disabled": false,
      "autoApprove": [
        "search_pubmed",
        "fetch_article",
        "fetch_abstract",
        "verify_citation",
        "search_by_title"
      ]
    },
    "suppevo": {
      "command": "python",
      "args": ["-m","suppevo_mcp.server"],
      "disabled": false,
      "autoApprove": []
    },
    "wigolo": {
      "command": "npx",
      "args": ["-y", "wigolo"],
      "disabled": false,
      "autoApprove": [
        "search",
        "fetch",
        "crawl",
        "extract",
        "find_similar",
        "cache",
        "diff",
        "watch",
        "research",
        "agent"
      ]
    },
    "firecrawl-mcp": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": ""
      },
      "disabled": true,
      "autoApprove": [
        "firecrawl_scrape",
        "firecrawl_map",
        "firecrawl_crawl",
        "firecrawl_extract",
        "firecrawl_interact",
        "firecrawl_interact_stop"
      ]
    }
  }
}
